<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BudgetHotel | Affordable Hotel Reservations</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Assignment.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2" style="color: hsl(var(--primary));">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    <span style="color: hsl(var(--foreground));">BudgetStay</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarContent">
                    <div class="d-lg-flex justify-content-between w-100 align-items-center">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Room" asp-action="Catalog" style="color: hsl(var(--muted-foreground));">Hotels</a>
                        </li>
                        @if (AuthenticationHelper.IsAuthenticated(Context))
                        {
                            var userRole = AuthenticationHelper.GetUserRole(Context);
                            @if (userRole == UserRole.Admin || userRole == UserRole.Manager || userRole == UserRole.Staff)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" style="color: hsl(var(--muted-foreground));">
                                        Admin
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="bi bi-people me-2"></i>Users</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Hotels"><i class="bi bi-building me-2"></i>Hotels</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Rooms"><i class="bi bi-door-open me-2"></i>Rooms</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Bookings"><i class="bi bi-calendar-check me-2"></i>Bookings</a></li>
                                    </ul>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Booking" asp-action="MyBookings" style="color: hsl(var(--muted-foreground));">My Bookings</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (AuthenticationHelper.IsAuthenticated(Context))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" style="color: hsl(var(--muted-foreground));">
                                    <span>@AuthenticationHelper.GetUserEmail(Context)</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Customer" asp-action="Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Security" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-area="" asp-controller="Security" asp-action="Login" style="color: hsl(var(--primary-foreground));">Sign In</a>
                            </li>
                        }
                    </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-links">
                <div class="d-flex align-items-center gap-2">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--primary));">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    <div>
                        <span class="fw-bold d-block" style="font-size: 1.25rem; color: hsl(var(--foreground));">BudgetStay</span>
                        <small class="text-muted">Your trusted partner for affordable accommodation worldwide.</small>
                    </div>
                </div>
                <ul class="footer-nav">
                    <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                    <li><a asp-controller="Home" asp-action="Careers">Careers</a></li>
                    <li><a asp-controller="Home" asp-action="Press">Press</a></li>
                    <li><a asp-controller="Home" asp-action="Blog">Blog</a></li>
                    <li><a asp-controller="Home" asp-action="HelpCenter">Help Center</a></li>
                    <li><a asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                    <li><a asp-controller="Home" asp-action="Terms">Terms of Service</a></li>
                </ul>
            </div>
            <div class="footer-bottom text-center">
                <p class="mb-0 text-muted" style="font-size: 0.875rem;">&copy; 2025 BudgetStay. All rights reserved.</p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
