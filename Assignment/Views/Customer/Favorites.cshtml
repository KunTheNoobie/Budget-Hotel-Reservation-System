@* 
    Favorites/Wishlist View
    Displays all room types that the user has added to their favorites.
    Shows room cards with images, pricing, and options to view details or remove from favorites.
*@
@model List<Assignment.Models.FavoriteRoomType>
@{
    ViewData["Title"] = "My Favorites";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-heart-fill text-danger me-2"></i>My Favorites</h2>
        <a asp-controller="Room" asp-action="Catalog" class="btn btn-outline-primary">
            <i class="bi bi-search me-2"></i>Browse More Rooms
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-heart fs-1 text-muted mb-3 d-block"></i>
            <h4 class="text-muted">No favorites yet</h4>
            <p class="text-muted">Start adding rooms to your favorites to save them for later!</p>
            <a asp-controller="Room" asp-action="Catalog" class="btn btn-primary mt-3">
                <i class="bi bi-search me-2"></i>Browse Rooms
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var favorite in Model)
            {
                var roomType = favorite.RoomType;
                if (roomType == null) continue;

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        @if (roomType.RoomImages.Any())
                        {
                            <img src="@roomType.RoomImages.First().ImageUrl" class="card-img-top" alt="@roomType.Name" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted fs-1"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@roomType.Name</h5>
                            <p class="card-text text-muted small">@(roomType.Description?.Length > 100 ? roomType.Description.Substring(0, 100) + "..." : roomType.Description)</p>
                            <div class="mb-2">
                                <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                                <small class="text-muted">@roomType.Hotel?.City, @roomType.Hotel?.Country</small>
                            </div>
                            <div class="mb-2">
                                <i class="bi bi-people text-muted me-1"></i>
                                <small class="text-muted">@roomType.Occupancy person(s)</small>
                            </div>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <span class="h5 text-primary mb-0">RM @roomType.BasePrice.ToString("F0")</span>
                                        <small class="text-muted d-block">per night</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Room" asp-action="Details" asp-route-id="@roomType.RoomTypeId" class="btn btn-primary flex-grow-1">
                                        <i class="bi bi-eye me-1"></i>View Details
                                    </a>
                                    <button type="button" class="btn btn-outline-danger remove-favorite-btn" data-room-type-id="@roomType.RoomTypeId" title="Remove from favorites">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer text-muted small">
                            <i class="bi bi-clock me-1"></i>Added @favorite.AddedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.remove-favorite-btn').on('click', function() {
                var btn = $(this);
                var roomTypeId = btn.data('room-type-id');
                
                if (confirm('Remove this room from your favorites?')) {
                    $.post('/Customer/RemoveFromFavorites', { roomTypeId: roomTypeId }, function(data) {
                        if (data.success) {
                            btn.closest('.col-md-6').fadeOut(300, function() {
                                $(this).remove();
                                // Check if no favorites left
                                if ($('.col-md-6').length === 0) {
                                    location.reload();
                                }
                            });
                            if (typeof showToast === 'function') {
                                showToast(data.message, 'success');
                            }
                        } else {
                            if (typeof showToast === 'function') {
                                showToast(data.message, 'error');
                            }
                        }
                    }).fail(function() {
                        if (typeof showToast === 'function') {
                            showToast('An error occurred. Please try again.', 'error');
                        }
                    });
                }
            });
        });
    </script>
}

