@model Assignment.Models.RoomType
@{
    ViewData["Title"] = "Edit Room Type";
    var hotels = ViewBag.Hotels as List<Assignment.Models.Hotel> ?? new List<Assignment.Models.Hotel>();
    var amenities = ViewBag.Amenities as List<Assignment.Models.Amenity> ?? new List<Assignment.Models.Amenity>();
    var selectedAmenityIds = Model.RoomTypeAmenities?.Select(rta => rta.AmenityId).ToList() ?? new List<int>();
}

<div class="container">
    <h2>Edit Room Type</h2>

    <form asp-action="EditRoomType" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="RoomTypeId" />
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" maxlength="100" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4" maxlength="1000"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Occupancy" class="form-label"></label>
                <input asp-for="Occupancy" class="form-control" type="number" min="1" max="10" required />
                <span asp-validation-for="Occupancy" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="BasePrice" class="form-label"></label>
                <input asp-for="BasePrice" class="form-control" type="number" step="0.01" min="0" max="99999.99" required />
                <span asp-validation-for="BasePrice" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="HotelId" class="form-label"></label>
            <select asp-for="HotelId" class="form-select" required>
                <option value="">-- Select Hotel --</option>
                @foreach (var hotel in hotels)
                {
                    <option value="@hotel.HotelId" selected="@(hotel.HotelId == Model.HotelId)">@hotel.Name - @hotel.City</option>
                }
            </select>
            <span asp-validation-for="HotelId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Current Images</label>
            @if (Model.RoomImages != null && Model.RoomImages.Any())
            {
                <div class="row mb-2">
                    @foreach (var image in Model.RoomImages)
                    {
                        <div class="col-md-3 mb-2">
                            <div class="position-relative">
                                <img src="@image.ImageUrl" alt="@image.Caption" class="img-thumbnail" style="max-height: 150px; width: 100%; object-fit: cover;" onerror="this.style.display='none';" />
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1" onclick="deleteRoomImage(@image.ImageId)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            <small class="d-block text-center mt-1">@image.Caption</small>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No images yet.</p>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Add New Image</label>
            <div class="mb-2">
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                <small class="form-text text-muted">Upload a new image file (JPG, PNG, GIF, etc.)</small>
            </div>
            <div class="text-muted mb-2">OR</div>
            <div>
                <input type="url" name="imageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                <small class="form-text text-muted">Enter a full URL to an image (leave empty to keep current images)</small>
            </div>
            <small class="form-text text-muted">You can delete images using the delete button above each image.</small>
        </div>

        <div class="mb-3">
            <label class="form-label">Amenities</label>
            @if (amenities.Any())
            {
                <div class="border rounded p-3" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var amenity in amenities)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="selectedAmenities" value="@amenity.AmenityId" id="amenity_@amenity.AmenityId" 
                                   checked="@(selectedAmenityIds.Contains(amenity.AmenityId))" />
                            <label class="form-check-label" for="amenity_@amenity.AmenityId">
                                @if (!string.IsNullOrEmpty(amenity.ImageUrl))
                                {
                                    <img src="@amenity.ImageUrl" alt="@amenity.Name" class="me-2" style="width: 20px; height: 20px; object-fit: cover;" onerror="this.style.display='none';">
                                }
                                @amenity.Name
                            </label>
                        </div>
                    }
                </div>
                <small class="form-text text-muted">Select amenities available in this room type</small>
            }
            else
            {
                <p class="text-muted">No amenities available. <a asp-action="Amenities">Create amenities first</a>.</p>
            }
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-action="RoomTypes" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function deleteRoomImage(imageId) {
            if (confirm('Are you sure you want to delete this image?')) {
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("DeleteRoomImage", "Admin")?imageId=' + imageId;
                
                var tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token;
                form.appendChild(tokenInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}

