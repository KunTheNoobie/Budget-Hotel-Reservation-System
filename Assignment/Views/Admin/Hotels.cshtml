@model List<Assignment.Models.Hotel>
@{
    ViewData["Title"] = "Hotel Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Hotel Management</h2>
        <a asp-action="CreateHotel" class="btn btn-primary">Create New Hotel</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form method="get" class="mb-3">
                <div class="row">
                    <div class="col-md-8">
                        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by name or city..." />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-secondary">Search</button>
                        <a asp-action="Hotels" class="btn btn-outline-secondary">Clear</a>
                    </div>
                </div>
            </form>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>Country</th>
                        <th>Contact</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hotel in Model)
                    {
                        <tr>
                            <td>@hotel.HotelId</td>
                            <td>
                                @if (!string.IsNullOrEmpty(hotel.ImageUrl))
                                {
                                    <img src="@hotel.ImageUrl" alt="@hotel.Name" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/50?text=No+Image'">
                                }
                                else
                                {
                                    <span class="text-muted">No Image</span>
                                }
                            </td>
                            <td>@hotel.Name</td>
                            <td>@hotel.Address</td>
                            <td>@hotel.City</td>
                            <td>@hotel.Country</td>
                            <td>@(hotel.ContactNumber ?? hotel.ContactEmail ?? "-")</td>
                            <td>
                                <a asp-action="EditHotel" asp-route-id="@hotel.HotelId" class="btn btn-sm btn-primary">Edit</a>
                                <form asp-action="DeleteHotel" asp-route-id="@hotel.HotelId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this hotel?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (ViewBag.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="?page=@i&searchTerm=@ViewBag.SearchTerm">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

