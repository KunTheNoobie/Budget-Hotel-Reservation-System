@* 
    Email Verification View
    Displays email verification page where users can verify their email address.
    Users can click verification link or manually enter verification token.
*@
@{
    ViewData["Title"] = "Verify Email";
    var userId = ViewBag.UserId as int?;
    var email = ViewBag.Email as string;
    var token = ViewBag.Token as string;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white text-center">
                    <h3><i class="bi bi-envelope-check"></i> Email Verification</h3>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            <h5><i class="bi bi-check-circle"></i> Email Sent!</h5>
                            <p>@TempData["SuccessMessage"]</p>
                            <p class="mb-0">Please check your inbox and click the verification link to activate your account.</p>
                        </div>
                    }
                    else if (TempData["WarningMessage"] != null)
                    {
                        <div class="alert alert-warning">
                            <h5><i class="bi bi-exclamation-triangle"></i> Email Sending Failed</h5>
                            <p>@TempData["WarningMessage"]</p>
                            @if (userId.HasValue && !string.IsNullOrEmpty(token))
                            {
                                <hr />
                                <p>Please use the verification link below:</p>
                                <div class="mt-3">
                                    <a href="@Url.Action("ConfirmEmail", "Security", new { userId = userId, token = token })" 
                                       class="btn btn-primary btn-lg">
                                        Verify Email Address
                                    </a>
                                </div>
                                <p class="mt-3 text-muted">
                                    <small>Or copy this link: <br />
                                    <code>@Url.Action("ConfirmEmail", "Security", new { userId = userId, token = token }, Context.Request.Scheme)</code>
                                    </small>
                                </p>
                            }
                        </div>
                    }
                    else if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">
                            <h5><i class="bi bi-check-circle"></i> @ViewBag.Success</h5>
                            <a asp-action="Login" class="btn btn-primary">Go to Login</a>
                        </div>
                    }
                    else if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <h5><i class="bi bi-x-circle"></i> @ViewBag.Error</h5>
                        </div>
                    }
                    else if (userId.HasValue && !string.IsNullOrEmpty(token))
                    {
                        <div class="alert alert-info">
                            <h5>Please verify your email address</h5>
                            <p>An email verification link has been sent to <strong>@email</strong></p>
                            <p>Click the link below to verify your email:</p>
                            <div class="mt-3">
                                <a href="@Url.Action("ConfirmEmail", "Security", new { userId = userId, token = token })" 
                                   class="btn btn-primary btn-lg">
                                    Verify Email Address
                                </a>
                            </div>
                            <p class="mt-3 text-muted">
                                <small>Or copy this link: <br />
                                <code>@Url.Action("ConfirmEmail", "Security", new { userId = userId, token = token }, Context.Request.Scheme)</code>
                                </small>
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <h5><i class="bi bi-envelope"></i> Verification Required</h5>
                            <p>Please check your email for the verification link.</p>
                            <p class="mb-0">If you didn't receive the email, please check your spam folder or contact support.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

