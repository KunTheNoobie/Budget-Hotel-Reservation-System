@model Assignment.Models.RoomType
@{
    ViewData["Title"] = "Room Details";
    var availableRooms = ViewBag.AvailableRooms as int? ?? 0;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
            <h2>@Model.Name</h2>
                @if (Model.Hotel != null)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        @if (!string.IsNullOrEmpty(Model.Hotel.ImageUrl))
                        {
                            <img src="@Model.Hotel.ImageUrl" alt="@Model.Hotel.Name" class="rounded" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.style.display='none';">
                        }
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi bi-building text-primary"></i>
                                <span class="fw-bold fs-5">@Model.Hotel.Name</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 text-muted">
                                <i class="bi bi-geo-alt-fill"></i>
                                <span>@Model.Hotel.City, @Model.Hotel.Country</span>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Hotel.Address))
                            {
                                <div class="text-muted small">
                                    <i class="bi bi-map"></i> @Model.Hotel.Address
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            
            @if (Model.RoomImages.Any())
            {
                <div id="roomCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.RoomImages.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Model.RoomImages.ElementAt(i).ImageUrl" class="d-block w-100" alt="Room Image" style="height: 400px; object-fit: cover;">
                            </div>
                        }
                    </div>
                    @if (Model.RoomImages.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="bg-secondary d-flex align-items-center justify-content-center mb-4" style="height: 400px;">
                    <span class="text-white">No Images Available</span>
                </div>
            }

            <div class="card mb-4">
                <div class="card-body">
                    <h5>Description</h5>
                    <p>@Model.Description</p>
                </div>
            </div>

            @if (Model.RoomTypeAmenities.Any())
            {
                <div class="card">
                    <div class="card-body">
                        <h5>Amenities</h5>
                        <div class="row">
                            @foreach (var amenity in Model.RoomTypeAmenities.Select(rta => rta.Amenity))
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(amenity.ImageUrl))
                                        {
                                            <img src="@amenity.ImageUrl" alt="@amenity.Name" class="me-2" style="width: 32px; height: 32px; object-fit: cover; border-radius: 4px;" onerror="this.style.display='none';">
                                        }
                                        <span>@amenity.Name</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Reviews Section -->
            <div class="card mt-4">
                <div class="card-body">
                    <h4 class="mb-4">Guest Reviews</h4>
                    @{
                        var allReviews = ViewBag.AllReviews as List<Assignment.Models.Review> ?? new List<Assignment.Models.Review>();
                        var paginatedReviews = ViewBag.PaginatedReviews as List<Assignment.Models.Review> ?? new List<Assignment.Models.Review>();
                        var reviewCurrentPage = ViewBag.ReviewCurrentPage as int? ?? 1;
                        var reviewTotalPages = ViewBag.ReviewTotalPages as int? ?? 1;
                    }

                    @if (allReviews.Any())
                    {
                        <div class="d-flex align-items-center mb-4">
                            <h2 class="display-4 fw-bold text-primary mb-0 me-3">@allReviews.Average(r => r.Rating).ToString("0.0")</h2>
                            <div>
                                <div class="text-warning fs-5">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= Math.Round(allReviews.Average(r => r.Rating)) ? "-fill" : "")"></i>
                                    }
                                </div>
                                <small class="text-muted">Based on @allReviews.Count review(s)</small>
                            </div>
                        </div>

                        <div class="review-list">
                            @foreach (var review in paginatedReviews)
                            {
                                <div class="review-item border-bottom pb-3 mb-3">
                                    <div class="d-flex align-items-start mb-2">
                                        <div class="me-3" style="position: relative; width: 45px; height: 45px;">
                                            @{
                                                // Ensure User is loaded - try both Review.User and Booking.User
                                                var reviewUser = review.User ?? review.Booking?.User;
                                                var hasProfilePicture = reviewUser != null && !string.IsNullOrWhiteSpace(reviewUser.ProfilePictureUrl);
                                            }
                                            @if (hasProfilePicture)
                                            {
                                                <img src="@Url.Content(reviewUser.ProfilePictureUrl)" alt="@reviewUser.FullName" 
                                                     class="rounded-circle" style="width: 45px; height: 45px; object-fit: cover; position: absolute; top: 0; left: 0;" 
                                                     onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                                <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-circle" style="display: none; width: 45px; height: 45px; font-size: 0.9rem; position: absolute; top: 0; left: 0;">
                                                    @(reviewUser.FullName?.Substring(0, 1).ToUpper() ?? "G")
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-circle" style="width: 45px; height: 45px; font-size: 0.9rem;">
                                                    @(reviewUser?.FullName?.Substring(0, 1).ToUpper() ?? "G")
                                                </div>
                                            }
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h6 class="mb-1">@review.User?.FullName</h6>
                                                    <div class="text-warning small mb-2">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                                        }
                                                    </div>
                                                </div>
                                                <small class="text-muted">@review.ReviewDate.ToString("MMM dd, yyyy")</small>
                                            </div>
                                            <p class="mb-0 text-muted">@review.Comment</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (reviewTotalPages > 1)
                        {
                            <nav aria-label="Review pagination" class="mt-4">
                                <ul class="pagination justify-content-center">
                                    @if (reviewCurrentPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?reviewPage=@(reviewCurrentPage - 1)">Previous</a>
                                        </li>
                                    }

                                    @for (int i = 1; i <= reviewTotalPages; i++)
                                    {
                                        @if (i == 1 || i == reviewTotalPages || (i >= reviewCurrentPage - 2 && i <= reviewCurrentPage + 2))
                                        {
                                            <li class="page-item @(i == reviewCurrentPage ? "active" : "")">
                                                <a class="page-link" href="?reviewPage=@i">@i</a>
                                            </li>
                                        }
                                        else if (i == reviewCurrentPage - 3 || i == reviewCurrentPage + 3)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                    }

                                    @if (reviewCurrentPage < reviewTotalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="?reviewPage=@(reviewCurrentPage + 1)">Next</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-chat-square-text fs-1 mb-2"></i>
                            <p>No reviews yet. Be the first to stay and review!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm" style="border-top: 4px solid var(--primary);">
                <div class="card-body p-4">
                    <h4 class="card-title mb-3">RM @Model.BasePrice.ToString("F0") <small class="text-muted fs-6 fw-normal">/night</small></h4>
                    <p class="mb-4"><i class="bi bi-people text-muted me-2"></i><strong>Occupancy:</strong> @Model.Occupancy person(s)</p>

                    @if (Assignment.Helpers.AuthenticationHelper.IsAuthenticated(Context))
                    {
                        <hr class="my-4" />
                        <h5 class="mb-3">Book This Room</h5>
                        <form id="availabilityForm">
                            <div class="mb-3">
                                <label for="checkIn" class="form-label">Check-In Date</label>
                                <input type="date" id="checkIn" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label for="checkOut" class="form-label">Check-Out Date</label>
                                <input type="date" id="checkOut" class="form-control" required />
                            </div>
                            <div id="availabilityMessage" class="mb-3">
                                @* Initial message - will be replaced when user checks availability *@
                                @if (availableRooms > 0)
                                {
                                    <div class="alert alert-info" id="initialAvailabilityMessage">
                                        <i class="bi bi-info-circle me-2"></i>@availableRooms room(s) currently available. Select dates to check specific availability.
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning" id="initialAvailabilityMessage">
                                        <i class="bi bi-exclamation-triangle me-2"></i>No rooms currently available. Check specific dates for availability.
                                    </div>
                                }
                            </div>
                            <button type="button" id="checkAvailabilityBtn" class="btn btn-primary w-100 mb-2">Check Availability</button>
                            <a id="bookNowBtn" asp-controller="Booking" asp-action="Create" asp-route-roomTypeId="@Model.RoomTypeId" class="btn btn-warning w-100 fw-bold" style="display: none;">Book Now</a>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-light border text-center">
                            <p class="mb-2">Sign in to book this room</p>
                            <a asp-controller="Security" asp-action="Login" class="btn btn-outline-primary w-100">Login</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var today = new Date().toISOString().split('T')[0];
            $('#checkIn').attr('min', today);
            $('#checkOut').attr('min', today);

            // Store initial message HTML
            var initialMessageHtml = $('#availabilityMessage').html();
            
            $('#checkIn').on('change', function() {
                var checkInDate = new Date($(this).val());
                checkInDate.setDate(checkInDate.getDate() + 1);
                $('#checkOut').attr('min', checkInDate.toISOString().split('T')[0]);
                // Reset to initial message when dates change
                $('#availabilityMessage').html(initialMessageHtml);
                $('#bookNowBtn').hide();
            });

            $('#checkOut').on('change', function() {
                // Reset to initial message when dates change
                $('#availabilityMessage').html(initialMessageHtml);
                $('#bookNowBtn').hide();
            });

            $('#checkAvailabilityBtn').on('click', function() {
                var checkIn = $('#checkIn').val();
                var checkOut = $('#checkOut').val();
                var roomTypeId = @Model.RoomTypeId;

                // Clear any existing messages first
                $('#availabilityMessage').empty();
                $('#bookNowBtn').hide();

                if (!checkIn || !checkOut) {
                    $('#availabilityMessage').html('<div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Please select both check-in and check-out dates.</div>');
                    return;
                }

                // Show loading state
                $('#availabilityMessage').html('<div class="alert alert-info"><i class="bi bi-hourglass-split me-2"></i>Checking availability...</div>');

                $.ajax({
                    url: '@Url.Action("CheckAvailability", "Room")',
                    type: 'POST',
                    cache: false,
                    data: {
                        roomTypeId: roomTypeId,
                        checkIn: checkIn,
                        checkOut: checkOut
                    },
                    success: function(response) {
                        // Clear the message container completely before adding new message
                        $('#availabilityMessage').empty();
                        
                        if (response && response.available) {
                            var message = response.message || ('Available! ' + response.count + ' room(s) available.');
                            $('#availabilityMessage').html('<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>' + message + '</div>');
                            $('#bookNowBtn').show().attr('href', '/Booking/Create?roomTypeId=' + roomTypeId + '&checkIn=' + checkIn + '&checkOut=' + checkOut);
                        } else {
                            var message = (response && response.message) ? response.message : 'No rooms available for the selected dates. Please try different dates.';
                            $('#availabilityMessage').html('<div class="alert alert-danger"><i class="bi bi-x-circle me-2"></i>' + message + '</div>');
                            $('#bookNowBtn').hide();
                        }
                    },
                    error: function(xhr, status, error) {
                        // Clear the message container completely before adding error message
                        $('#availabilityMessage').empty();
                        
                        var errorMessage = 'Error checking availability. Please try again.';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        }
                        $('#availabilityMessage').html('<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>' + errorMessage + '</div>');
                        $('#bookNowBtn').hide();
                    }
                });
            });
        });
    </script>
}

