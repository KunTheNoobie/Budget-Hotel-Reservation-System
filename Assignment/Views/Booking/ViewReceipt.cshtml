@model Assignment.Models.Booking
@{
    ViewData["Title"] = "Booking Receipt";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white text-center">
            <h2>Budget Hotel Reservation</h2>
            <h3>Booking Receipt</h3>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>Booking Information</h5>
                    <p><strong>Booking ID:</strong> #@Model.BookingId</p>
                    <p><strong>Booking Date:</strong> @Model.BookingDate.ToString("MM/dd/yyyy HH:mm")</p>
                    <p><strong>Status:</strong> <span class="badge bg-primary">@Model.Status</span></p>
                </div>
                <div class="col-md-6 text-end">
                    <h5>Receipt</h5>
                    <p><strong>Date:</strong> @DateTime.Now.ToString("MM/dd/yyyy HH:mm")</p>
                </div>
            </div>

            <hr />

            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>Guest Information</h5>
                    <p><strong>Name:</strong> @Model.User.FullName</p>
                    <p><strong>Email:</strong> @Model.User.Email</p>
                    @if (!string.IsNullOrEmpty(Model.User.PhoneNumber))
                    {
                        <p><strong>Phone:</strong> @Model.User.PhoneNumber</p>
                    }
                </div>
                <div class="col-md-6">
                    <h5>Room Information</h5>
                    <p><strong>Room Number:</strong> @Model.Room.RoomNumber</p>
                    <p><strong>Room Type:</strong> @Model.Room.RoomType.Name</p>
                    <p><strong>Occupancy:</strong> @Model.Room.RoomType.Occupancy person(s)</p>
                </div>
            </div>

            <hr />

            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>Booking Dates</h5>
                    <p><strong>Check-In:</strong> @Model.CheckInDate.ToString("MM/dd/yyyy")</p>
                    <p><strong>Check-Out:</strong> @Model.CheckOutDate.ToString("MM/dd/yyyy")</p>
                    <p><strong>Nights:</strong> @((Model.CheckOutDate - Model.CheckInDate).Days)</p>
                </div>
                <div class="col-md-6">
                    <h5>Pricing</h5>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <tr>
                                <td>Base Price (@((Model.CheckOutDate - Model.CheckInDate).Days) nights × RM @Model.Room.RoomType.BasePrice.ToString("F2")):</td>
                                <td class="text-end">RM @((Model.CheckOutDate - Model.CheckInDate).Days * Model.Room.RoomType.BasePrice).ToString("F2")</td>
                            </tr>
                            @if (Model.Promotion != null)
                            {
                                <tr>
                                    <td>Promotion (@Model.Promotion.Code):</td>
                                    <td class="text-end text-danger">-RM @((Model.CheckOutDate - Model.CheckInDate).Days * Model.Room.RoomType.BasePrice - Model.TotalPrice).ToString("F2")</td>
                                </tr>
                            }
                            <tr class="table-active">
                                <td><strong>Total Amount:</strong></td>
                                <td class="text-end"><strong>RM @Model.TotalPrice.ToString("F2")</strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            @if (Model.Payment != null)
            {
                <hr />
                <div class="row mb-4">
                    <div class="col-md-12">
                        <h5>Payment Information</h5>
                        <p><strong>Amount Paid:</strong> RM @Model.Payment.Amount.ToString("F2")</p>
                        <p><strong>Payment Method:</strong> @Model.Payment.PaymentMethod</p>
                        <p><strong>Payment Status:</strong> <span class="badge bg-success">@Model.Payment.Status</span></p>
                        <p><strong>Payment Date:</strong> @Model.Payment.PaymentDate.ToString("MM/dd/yyyy HH:mm")</p>
                        @if (!string.IsNullOrEmpty(Model.Payment.TransactionId))
                        {
                            <p><strong>Transaction ID:</strong> @Model.Payment.TransactionId</p>
                        }
                    </div>
                </div>
            }

            <hr />

            <div class="text-center mt-4">
                <p class="text-muted">
                    <small>Thank you for choosing Budget Hotel Reservation!</small><br />
                    <small>For inquiries, please contact us at support@budgethotel.com</small>
                </p>
                <div class="mt-3">
                    <button onclick="window.print()" class="btn btn-primary">Print Receipt</button>
                    <a asp-action="MyBookings" class="btn btn-secondary">Back to My Bookings</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, .navbar, footer { display: none !important; }
        .card { border: none !important; box-shadow: none !important; }
    }
</style>

