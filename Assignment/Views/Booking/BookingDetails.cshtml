@model Assignment.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<div class="container mt-4">
    <h2>Booking Details</h2>

    <div class="card">
        <div class="card-body">
            <h4>Booking #@Model.BookingId</h4>
            
            <div class="row mt-4">
                <div class="col-md-6">
                    <h5>Room Information</h5>
                    <p><strong>Room Number:</strong> @Model.Room.RoomNumber</p>
                    <p><strong>Room Type:</strong> @Model.Room.RoomType.Name</p>
                    <p><strong>Occupancy:</strong> @Model.Room.RoomType.Occupancy person(s)</p>
                </div>
                <div class="col-md-6">
                    <h5>Booking Dates</h5>
                    <p><strong>Check-In:</strong> @Model.CheckInDate.ToString("MM/dd/yyyy")</p>
                    <p><strong>Check-Out:</strong> @Model.CheckOutDate.ToString("MM/dd/yyyy")</p>
                    <p><strong>Nights:</strong> @((Model.CheckOutDate - Model.CheckInDate).Days)</p>
                    <p><strong>Booking Date:</strong> @Model.BookingDate.ToString("MM/dd/yyyy HH:mm")</p>
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-6">
                    <h5>Pricing</h5>
                    <p><strong>Total Price:</strong> RM @Model.TotalPrice.ToString("F2")</p>
                    @if (Model.Promotion != null)
                    {
                        <p><strong>Promotion Applied:</strong> @Model.Promotion.Code</p>
                    }
                </div>
                <div class="col-md-6">
                    <h5>Status</h5>
                    <p><strong>Booking Status:</strong> <span class="badge bg-primary">@Model.Status</span></p>
                    @if (Model.Payment != null)
                    {
                        <p><strong>Payment Status:</strong> <span class="badge bg-success">@Model.Payment.Status</span></p>
                        <p><strong>Payment Method:</strong> @Model.Payment.PaymentMethod</p>
                    }
                </div>
            </div>

            <div class="mt-4">
                <a asp-action="MyBookings" class="btn btn-secondary">Back to My Bookings</a>
                @if (Model.Status != Assignment.Models.BookingStatus.Cancelled && Model.CheckInDate > DateTime.Today)
                {
                    <form asp-action="CancelBooking" asp-route-id="@Model.BookingId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                        <button type="submit" class="btn btn-danger">Cancel Booking</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

